{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "motion-studio": {
      "type": "local",
      "command": ["npx", "-y", "https://api.motion.dev/registry.tgz?package=motion-studio-mcp&version=latest"],
      "enabled": true
    },
    "motion-dev": {
      "type": "local",
      "command": [
        "node",
        "V:/mcp_server/motion-dev-mcp/dist/index.js"
      ],
      "enabled": true
    }
  }
}