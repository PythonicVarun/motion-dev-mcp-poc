{
  "mcpServers": {
    "motion-studio": {
      "command": "npx",
      "args": ["-y", "https://api.motion.dev/registry.tgz?package=motion-studio-mcp&version=latest"]
    },
    "motion-dev": {
      "command": "node",
      "args": ["V:/mcp_server/motion-dev-mcp/dist/index.js"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y", "@playwright/mcp@latest"
      ]
    }
  }
}